GOOGLE_API_KEY=AIza-your-key-here
OPENAI_API_KEY=
HUGGINGFACEHUB_API_TOKEN=
OPENAI_BASE_URL=
LLM_PROVIDER=auto
EMBEDDING_PROVIDER=auto
MODEL_NAME=gemini-2.5-flash
#gemini-3.5-flash
EMBEDDING_MODEL_NAME=models/gemini-embedding-2
# Optional: path to the Tesseract binary if it is not on PATH (for scanned-PDF OCR)
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
RAG_SEARCH_TYPE=similarity
RAG_TOP_K=4
RAG_FETCH_K=12
RAG_MMR_LAMBDA=0.65
# Drop retrieved lore below this relevance score (0..1) on the grounding path.
# 0 = keep everything. Raise (e.g. 0.2) to stop weak matches polluting NPC prompts.
RAG_SCORE_THRESHOLD=0.2
RAG_CHUNK_SIZE=900
RAG_CHUNK_OVERLAP=150
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=your_key_here
